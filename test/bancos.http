### Ver bancos

GET http://localhost:8080/api/bancos HTTP/1.1

### Obtener un banco

# @prompt bancoId

GET http://localhost:8080/api/bancos/{{bancoId}} HTTP/1.1

### Crear banco

POST http://localhost:8080/api/bancos HTTP/1.1
content-type: application/json

{
  "difficulty": "dificil",
  "address": "Calle Alcala 123, Madrid",
  "available": true,
  "image": "banco-central-madrid.jpg",
  "name": "Banco Central Madrid",
  "reward": 250000
}

### Crear varios bancos

POST http://localhost:8080/api/bancos HTTP/1.1
content-type: application/json

[
  {
    "difficulty": "facil",
    "address": "Avenida de la Paz 45, Valencia",
    "available": true,
    "image": "sucursal-valencia.jpg",
    "name": "Sucursal Valencia",
    "reward": 90000
  },
  {
    "difficulty": "medio",
    "address": "Gran Via 78, Barcelona",
    "available": true,
    "image": "deposito-barcelona.jpg",
    "name": "Deposito Barcelona",
    "reward": 160000
  }
]

### Actualizar un banco

# @prompt bancoId

PUT http://localhost:8080/api/bancos/{{bancoId}} HTTP/1.1
content-type: application/json

{
  "difficulty": "medio",
  "address": "Paseo de Recoletos 15, Madrid",
  "available": true,
  "image": "banco-recoletos.jpg",
  "name": "Banco Recoletos",
  "reward": 180000
}

### Eliminar todos los bancos

DELETE http://localhost:8080/api/bancos HTTP/1.1

### Eliminar un banco

# @prompt bancoId

DELETE http://localhost:8080/api/bancos/{{bancoId}} HTTP/1.1
